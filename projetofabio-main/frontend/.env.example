# VITE_APP_MODE controla o LOGIN no frontend:
#   demo     -> login simples por email/senha (recomendado p/ a demo persistente)
#   firebase -> login via Firebase Auth (exige as credenciais abaixo)
# Mantenha 'demo' para usar o login simples mesmo com o backend gravando no
# Firestore real (backend com APP_MODE=firebase + ENABLE_DEMO_LOGIN=true).
VITE_APP_MODE=demo
VITE_API_URL=http://localhost:3001

# Preencha abaixo somente se VITE_APP_MODE=firebase (login via Firebase Auth)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
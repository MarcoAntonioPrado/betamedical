# APP_MODE controla o ARMAZENAMENTO:
#   demo     -> arquivo JSON local (efêmero, não persiste em serverless)
#   firebase -> Firestore real (persistente). Requer as credenciais abaixo.
APP_MODE=firebase
PORT=3001
FRONTEND_URL=http://localhost:5173

# ENABLE_DEMO_LOGIN=true mantém o login demo simples (email/senha) funcionando
# mesmo com APP_MODE=firebase. Assim o usuário demo cria/edita/apaga com
# persistência real no Firestore, sem precisar de usuários no Firebase Auth.
# Defina como false para exigir somente login via Firebase Auth.
ENABLE_DEMO_LOGIN=true

# Necessário quando APP_MODE=firebase (baixe a chave em
# Firebase Console > Configurações do projeto > Contas de serviço)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
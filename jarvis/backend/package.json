{
  "name": "dev-assistant-local-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":          "node node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "start":        "node node_modules/tsx/dist/cli.mjs src/index.ts",
    "build":        "tsc",
    "db:generate":  "prisma generate",
    "db:migrate":   "prisma migrate dev --name init",
    "db:studio":    "prisma studio",
    "db:reset":     "prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/client":     "^5.13.0",
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.5",
    "express":            "^4.19.2",
    "express-validator":  "^7.1.0"
  },
  "devDependencies": {
    "@types/cors":    "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node":    "^20.12.0",
    "prisma":         "^5.13.0",
    "tsx":            "^4.7.3",
    "typescript":     "^5.4.5"
  }
}

{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand":   "npm run dev:frontend",
    "beforeBuildCommand": "npm run build",
    "devPath":            "http://localhost:1420",
    "distDir":            "../dist",
    "withGlobalTauri":    true
  },
  "package": {
    "productName": "Dev Assistant Local",
    "version":     "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all":  false,
        "open": true
      }
    },
    "bundle": {
      "active":      true,
      "category":    "DeveloperTool",
      "identifier":  "com.devassistant.local",
      "shortDescription": "Assistente de produtividade para devs",
      "longDescription":  "Dev Assistant Local — Projetos, tarefas e IA, tudo offline.",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "targets": "all",
      "externalBin": [],
      "resources":   [],
      "macOS": {
        "entitlements":      null,
        "exceptionDomain":   "",
        "frameworks":        [],
        "providerShortName": null,
        "signingIdentity":   null
      },
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm":       "sha256",
        "timestampUrl":          ""
      },
      "deb": { "depends": [] }
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:3001; img-src 'self' data:"
    },
    "updater": { "active": false },
    "windows": [
      {
        "title":     "Dev Assistant Local",
        "width":     1280,
        "height":    800,
        "minWidth":  900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center":    true
      }
    ]
  }
}
